<?xml version="1.0" encoding="UTF-8"?>
<LightningComponentBundle xmlns="http://soap.sforce.com/2006/04/metadata">
    <apiVersion>66.0</apiVersion>
    <isExposed>true</isExposed>
    <masterLabel>Electra Dealer Booking Card</masterLabel>
    <description>Single booking row with status-aware actions + optional OmniStudio launcher for the Capture Outcome step.</description>
    <targets>
        <target>lightning__AppPage</target>
        <target>lightning__RecordPage</target>
        <target>lightningCommunity__Default</target>
    </targets>
    <targetConfigs>
        <targetConfig targets="lightning__AppPage,lightning__RecordPage,lightningCommunity__Default">
            <property name="useOmniScript" type="Boolean" label="Use OmniScript wizard for Capture Outcome" default="false" description="Flip ON after Saumyadeep activates OS_CapturePostDriveOutcome."/>
            <property name="omniScriptType" type="String" label="OmniScript Type" default="Capture"/>
            <property name="omniScriptSubType" type="String" label="OmniScript Sub Type" default="PostDriveOutcome"/>
            <property name="omniScriptLanguage" type="String" label="OmniScript Language" default="English"/>
        </targetConfig>
    </targetConfigs>
</LightningComponentBundle>