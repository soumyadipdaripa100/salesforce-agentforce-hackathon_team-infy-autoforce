<?xml version="1.0" encoding="UTF-8"?>
<LightningComponentBundle xmlns="http://soap.sforce.com/2006/04/metadata">
    <apiVersion>66.0</apiVersion>
    <isExposed>true</isExposed>
    <targets>
        <target>lightning__AppPage</target>
        <target>lightning__HomePage</target>
        <target>lightningCommunity__Page</target>
        <target>lightningCommunity__Default</target>
    </targets>
    <masterLabel>Electra Top Nav</masterLabel>
    <description>Global site navigation bar with brand, 5 tabs, and page-level active highlighting.</description>
    <targetConfigs>
        <targetConfig targets="lightning__AppPage,lightning__HomePage,lightningCommunity__Default">
            <property name="activePage"
                      type="String"
                      label="Active page"
                      default="home"
                      datasource="home,dealer,book,catalog,contact,dealerLogin"
                      description="Which tab should appear highlighted on this page." />
        </targetConfig>
    </targetConfigs>
</LightningComponentBundle>