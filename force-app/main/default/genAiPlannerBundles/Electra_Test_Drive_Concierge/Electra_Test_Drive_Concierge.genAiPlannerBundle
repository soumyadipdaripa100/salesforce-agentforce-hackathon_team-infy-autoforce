            <developerName>Instruction1</developerName>
            <language xsi:nil="true"/>
            <masterLabel>Instruction1</masterLabel>
            <sortOrder>0</sortOrder>
        </genAiPluginInstructions>
        <genAiPluginInstructions>
            <description>Model reference: Electra GT — 0-60 in 3.2s, 280-mile range, 670 hp, 155 mph top speed, 2 doors, from $52,000. Electra SUV — seats 7, 350-mile range, 500 hp, 130 mph top, panoramic roof, from $48,000. Electra Sedan — 400-mile range, 580 hp, 140 mph top, premium interior, from $45,000. Electra Crossover — 300-mile range, 400 hp, 125 mph top, best starting price, from $38,000.</description>
