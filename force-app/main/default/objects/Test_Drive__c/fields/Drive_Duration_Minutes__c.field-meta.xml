<?xml version="1.0" encoding="UTF-8"?>
<CustomField xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Drive_Duration_Minutes__c</fullName>
    <description>Duration of the test drive in minutes, computed from Drive_Started_At__c and Drive_Ended_At__c.</description>
    <externalId>false</externalId>
    <formula>IF(AND(NOT(ISBLANK(Drive_Started_At__c)), NOT(ISBLANK(Drive_Ended_At__c))), (Drive_Ended_At__c - Drive_Started_At__c) * 1440, NULL)</formula>
    <formulaTreatBlanksAs>BlankAsZero</formulaTreatBlanksAs>
    <label>Drive Duration (Minutes)</label>
    <precision>18</precision>
    <required>false</required>
    <scale>0</scale>
    <trackHistory>false</trackHistory>
    <trackTrending>false</trackTrending>
    <type>Number</type>
    <unique>false</unique>
</CustomField>
